# Trustee MCP Server Configuration
#
# Copy this file to .env and adjust the paths to match your local setup
# These environment variables override the default paths

# Path to the trustee-operator repository
# Default: ~/git/trustee-operator
TRUSTEE_REPO_PATH=/path/to/trustee-operator

# Path to the veritas repository
# Default: ~/git/veritas
VERITAS_REPO_PATH=/path/to/veritas
